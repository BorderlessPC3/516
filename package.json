{
  "name": "herois-dos-premios",
  "version": "1.0.0",
  "private": true,
  "description": "Heróis dos Prêmios - Monorepo",
  "workspaces": [
    "shared",
    "herois-dos-premios-app",
    "painel-web",
    "firebase/functions"
  ],
  "scripts": {
    "dev:app": "npm run start --workspace=herois-dos-premios-app",
    "dev:web": "npm run dev --workspace=painel-web",
    "dev:functions": "npm run serve --workspace=firebase-functions",
    "build": "npm run build --workspaces --if-present",
    "build:shared": "npm run build --workspace=@herois/shared",
    "build:web": "npm run build --workspace=painel-web",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "prepare": "husky",
    "seed": "tsx scripts/seed-firestore.ts",
    "firebase:deploy": "firebase deploy",
    "firebase:deploy:rules": "firebase deploy --only firestore:rules,storage"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "firebase-admin": "^13.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "react-native": "0.81.5"
  },
  "overrides": {
    "expo-linking": "~8.0.12",
    "expo-application": "~7.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "metro-config": "0.83.7"
  }
}
