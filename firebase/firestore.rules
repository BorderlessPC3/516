rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isActive == true;
    }

    function isSuperAdmin() {
      return isAdmin() &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'SUPER_ADMIN';
    }

    function adminRole() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role;
    }

    function hasAdminRole(roles) {
      return isAdmin() && adminRole() in roles;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow create, update: if hasAdminRole(['SUPER_ADMIN', 'ADMIN']);
      allow delete: if isSuperAdmin();
    }

    match /campaigns/{campaignId} {
      allow read: if isAuthenticated();
      allow create, update: if hasAdminRole(['SUPER_ADMIN', 'ADMIN']);
      allow delete: if hasAdminRole(['SUPER_ADMIN', 'ADMIN']);
    }

    match /campaignVideos/{videoId} {
      allow read: if isAuthenticated();
      allow write: if hasAdminRole(['SUPER_ADMIN', 'ADMIN']);
    }

    match /campaignImages/{imageId} {
      allow read: if isAuthenticated();
      allow write: if hasAdminRole(['SUPER_ADMIN', 'ADMIN']);
    }

    match /coupons/{couponId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if hasAdminRole(['SUPER_ADMIN', 'ADMIN']);
      allow delete: if hasAdminRole(['SUPER_ADMIN', 'ADMIN']);
    }

    match /couponTemplates/{templateId} {
      allow read: if isAdmin();
      allow write: if hasAdminRole(['SUPER_ADMIN', 'ADMIN']);
    }

    match /draws/{drawId} {
      allow read: if isAuthenticated();
      allow write: if hasAdminRole(['SUPER_ADMIN', 'ADMIN']);
    }

    match /drawParticipants/{participantId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /prizes/{prizeId} {
      allow read: if isAuthenticated();
      allow write: if hasAdminRole(['SUPER_ADMIN', 'ADMIN']);
    }

    match /coins/{walletId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    match /coinTransactions/{transactionId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isAdmin();
      allow write: if hasAdminRole(['SUPER_ADMIN', 'ADMIN', 'OPERADOR']);
    }

    match /videoProgress/{progressId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /videoViews/{viewId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /socialActions/{actionId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /qrScans/{scanId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if false;
      allow update, delete: if isAdmin();
    }

    match /campaignParticipations/{participationId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if false;
      allow delete: if isAdmin();
    }

    match /campaignQrCodes/{qrId} {
      allow read: if isAuthenticated();
      allow write: if hasAdminRole(['SUPER_ADMIN', 'ADMIN']);
    }

    match /analyticsEvents/{eventId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /cities/{cityId} {
      allow read: if isAuthenticated();
      allow write: if hasAdminRole(['SUPER_ADMIN', 'ADMIN']);
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if hasAdminRole(['SUPER_ADMIN', 'ADMIN']);
    }

    match /auditLogs/{logId} {
      allow read: if hasAdminRole(['SUPER_ADMIN', 'ADMIN']);
      allow write: if false;
    }
  }
}
